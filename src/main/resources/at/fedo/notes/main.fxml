<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="at.fedo.notes.controller.MainController">

    <top>
        <ToolBar>
            <Button text="New Note" onAction="#newNote"/>
            <Button text="New Folder" onAction="#newFolder"/>
            <Button text="Save" onAction="#saveNote"/>
            <Button text="Delete" onAction="#deleteNote"/>
        </ToolBar>
    </top>

    <left>
        <TreeView fx:id="noteTree" prefWidth="200"/>
    </left>

    <center>
        <TextArea fx:id="editor" wrapText="true"/>
    </center>

</BorderPane>
